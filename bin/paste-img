#!/usr/bin/env bash
# Save an image from the Wayland clipboard into a subfolder as
# YYYY-MM-DD_<description>.png, print a markdown link relative to the current
# directory, and copy that link back to the clipboard.
#
# Usage: paste-img [-f subfolder] <description>

set -euo pipefail

usage() {
    echo "usage: paste-img [-f subfolder] <description>" >&2
}

folder="assets/"

while getopts ":f:h" opt; do
    case "$opt" in
        f)
            folder="$OPTARG"
            ;;
        h)
            usage
            exit 0
            ;;
        :)
            echo "paste-img: -$OPTARG requires an argument" >&2
            usage
            exit 2
            ;;
        \?)
            echo "paste-img: unknown option -$OPTARG" >&2
            usage
            exit 2
            ;;
    esac
done
shift $((OPTIND - 1))

if [[ $# -lt 1 ]]; then
    echo "paste-img: description is required" >&2
    usage
    exit 2
fi

desc="$1"
# sanitize: spaces -> underscores, strip anything that isn't [A-Za-z0-9._-]
desc="${desc// /_}"
desc="$(printf '%s' "$desc" | tr -cd '[:alnum:]._-')"
if [[ -z "$desc" ]]; then
    echo "paste-img: description is empty after sanitization" >&2
    exit 2
fi

if [[ -z "$folder" ]]; then
    echo "paste-img: subfolder cannot be empty" >&2
    exit 2
fi

if [[ "$folder" = /* || "$folder" = *..* ]]; then
    echo "paste-img: subfolder must be relative and cannot contain '..'" >&2
    exit 2
fi

folder="${folder%/}"
link_dir="${folder#./}"

date="$(date +%Y-%m-%d)"
base="${date}_${desc}"
ext="png"

# Bail early if the clipboard doesn't hold an image.
if ! wl-paste -l 2>/dev/null | grep -q '^image/'; then
    echo "paste-img: clipboard does not contain an image" >&2
    exit 1
fi

mkdir -p "$folder"

# Pick a non-colliding filename: base.png, base-1.png, base-2.png, ...
file="${base}.${ext}"
n=1
while [[ -e "${folder}/${file}" ]]; do
    file="${base}-${n}.${ext}"
    n=$((n + 1))
done

wl-paste -t image/png > "${folder}/${file}"

link="![${desc}](${link_dir}/${file})"
printf '%s\n' "$link"
printf '%s' "$link" | wl-copy
