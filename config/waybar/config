{
    "layer": "bottom",
    "position": "top",

    "modules-left": ["sway/workspaces", "sway/mode", "sway/scratchpad", "custom/tailscale", "custom/wifi_debug"],
    "modules-center": ["custom/clock"],
    "modules-right": ["tray", "custom/power", "backlight", "pulseaudio", "network", "memory", "temperature", "battery", "cpu"],
    "sway/mode": {
        "format": "ΎΒΦΎΕΖ {}"
    },
    "sway/workspaces": {
        "format": "{name}",
        "disable-scroll": true
    },
    "sway/window": {
        "max-length": 80,
        "tooltip": false
    },
    "memory": {
        "format": "{used:0.1f}G/{total:0.1f}G ΌΚο  {swapUsed:0.1f}G ΎΑκ "
    },
    "clock": {
        "format": "{:%a %d %b %H:%M}",
        "tooltip": false
    },
    "custom/clock": {
        "format": "{}",
        "tooltip": false,
        "exec": "date +'%a %d %b %H:%M'",
        "interval": 10
    },
    "battery": {
        "format": "{capacity}% {icon}",
        "format-alt": "{time} {icon}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
        "format-charging": "{capacity}% ≤▒ΡΜ",
        "interval": 30,
        "states": {
            "warning": 25,
            "critical": 10
        },
        "tooltip": false
    },
    "network": {
        "format": "{icon}",
        "format-alt": "{ipaddr}/{cidr} {icon}",
        "format-alt-click": "click-right",
        "format-icons": {
            "wifi": ["≤░μ╛", "≤░μ┤", "≤░μ╢", "≤░μ╕", "≤░μ║"],
            "ethernet": ["≤░Να"],
            "disconnected": ["≤▒αΨ"]
        },
        "on-click": "termite -e nmtui",
    "tooltip": false
    },
    "pulseaudio": {
        "format": "{volume} {icon}",
        "format-alt": "{volume} {icon}",
        "format-alt-click": "click-right",
        "format-muted": "≤░ζθ",
        "format-icons": {
            "phone": ["ΎΑξ ≤░Χ┐", "ΎΑξ ≤░ΨΑ", "ΎΑξ ≤░Χ╛"],
            "default": ["≤░Χ┐", "≤░ΨΑ", "≤░Χ╛"]
        },
        "scroll-step": 5,
        "on-click": "pavucontrol",
        "tooltip": false
    },
    "backlight": {
        "format": "{percent} {icon}",
        "format-alt": "{percent} {icon}",
        "format-alt-click": "click-right",
        "format-icons": ["ΌΠΧ", "ΌΟρ", "ΌΟπ", "ΌΟο", "ΌΟξ", "ΌΟν", "ΌΟμ", "ΌΟλ", "ΌΟκ", "ΌΟι", "ΌΟθ", "ΌΟη", "ΌΟζ", "ΌΟε", "ΌΠμ"],
        "on-scroll-down": "light -A 1",
        "on-scroll-up": "light -U 1"
    },
    "tray": {
        "icon-size": 24,
        "show-passive-items": true,
        "spacing": 10
    },
    "temperature": {
        "format": "{temperatureC}┬░C ΎΜΜ"
    },
    "cpu": {
        "interval": 5,
        "format": "{min_frequency:.1f}|{max_frequency:.1f} {icon}",
        "format-icons": ["έΨΒ", "έΨΓ", "έΨΔ", "έΨΕ", "έΨΖ", "έΨΗ", "έΨΘ", "έΨΙ"]
    },
    "custom/power": {
      "exec": "sh ~/.config/waybar/get-power.sh",
      "format": "{}W ≤▒ΡΜ",
      "return-type": "",
      "interval": 5
    },
    "custom/tailscale": {
        "format": "{}",
        "interval": 30,
        "exec": "~/.config/waybar/tailscale.sh",
        "return-type": "json", 
        "tooltip": true
    },
    "custom/wifi_debug": {
        "exec": "~/.config/waybar/wifi_debug.py",
        "interval": 5,
        "return-type": "json",
        "format": " {}",
        "tooltip": true
    }
}
